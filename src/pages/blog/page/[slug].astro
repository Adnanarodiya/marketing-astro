---
import Pagination from "@/components/Pagination.astro";
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import { getListPage, getSinglePage } from "@/lib/contentParser.astro";
import { sortByDate } from "@/lib/utils/sortFunctions";
import BlogSection from "@/partials/BlogSection.astro";
import CallToAction from "@/partials/CallToAction.astro";

const BLOG_FOLDER = "blog";

const { slug } = Astro.params;
const allPosts = await getSinglePage(BLOG_FOLDER);
const posts = allPosts.filter((post) => post.id.startsWith("de/"));
const postIndex = await getListPage(
  BLOG_FOLDER,
  "de/-index"
);
if (postIndex.data.draft) {
  return Astro.redirect("/404");
}
const sortedPosts = sortByDate(posts);
const totalPages = Math.ceil(posts.length / config.settings.pagination);
const currentPage = slug && !isNaN(Number(slug)) ? Number(slug) : 1;
const indexOfLastPost = currentPage * config.settings.pagination;
const indexOfFirstPost = indexOfLastPost - config.settings.pagination;
const currentPosts = sortedPosts.slice(indexOfFirstPost, indexOfLastPost);

export async function getStaticPaths() {
  const BLOG_FOLDER = "blog";
  const allPosts = await getSinglePage(BLOG_FOLDER);
  const posts = allPosts.filter((post) => post.id.startsWith("de/"));
  const totalPages = Math.ceil(posts.length / config.settings.pagination);
  const paths = [];

  for (let i = 1; i < totalPages; i++) {
    paths.push({
      params: {
        slug: (i + 1).toString(),
      },
    });
  }
  return paths;
}
const { sections } = postIndex.data;
---

<Base {...postIndex.data}>
  {
    sections?.map((section) => {
      if (section.enable === false) {
        return null;
      }

      switch (section.type) {
        case "blog_section":
          if (section.card_layout === "creative") {
            return null;
          }
          return (
            <BlogSection
              largeHeading={section.large_heading}
              content={section}
              visiblePosts={section.visible_posts}
              posts={currentPosts}
            />
          );
        case "pagination":
          return (
            <Pagination
              section={BLOG_FOLDER}
              currentPage={currentPage}
              totalPages={totalPages}
            />
          );
        case "page_cta":
          return <CallToAction content={section} />;
        default:
          return null;
      }
    })
  }
</Base>
