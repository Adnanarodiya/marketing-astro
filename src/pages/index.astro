---
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import Clients from "@/partials/Clients.astro";
import HowItWorks from "@/partials/HowItWorks.astro";
import FeaturesGrid from "@/partials/FeaturesGrid.astro";
import FeatureSection from "@/partials/FeatureSection.astro";
import FeaturesExplanation from "@/partials/FeaturesExplanation.astro";
import PricingSection from "@/partials/PricingSection.astro";
import Testimonial from "@/partials/Testimonial.astro";
import CallToAction from "@/partials/CallToAction.astro";
import Faq from "@/partials/Faq.astro";
import config from "@/config/config.json";

const homepage = await getListPage("homepage", "-index");
if (homepage.data.draft) {
  return Astro.redirect("/404");
}

const { sections } = homepage.data;
const bannerSection = sections?.find((s) => s.type === "banner");

const homeSchema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": config.site.title,
    "url": config.site.base_url
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": config.site.title,
    "url": config.site.base_url,
    "logo": `${config.site.base_url}${config.site.logo}`,
    "description": config.params.footer_description
  }
];
---

<Base
  {...homepage.data}
  banner={bannerSection ? bannerSection.enable !== false : true}
  bannerData={bannerSection}
  schema={homeSchema}
>
  {
    sections?.map((section) => {
      // Toggle check: if enable is false, don't show the section.
      if (section.enable === false) {
        return null;
      }

      switch (section.type) {
        case "banner":
          // Handled inside Header via bannerData prop
          return null;
        case "clients":
          return <Clients content={section} />;
        case "how_it_works":
          return <HowItWorks content={section} />;
        case "features_grid":
          return <FeaturesGrid content={section} />;
        case "features_section":
          return <FeatureSection content={section} />;
        case "features_explanation":
          return <FeaturesExplanation content={section} />;
        case "pricing":
          return <PricingSection content={section} />;
        case "testimonial":
          return <Testimonial visible_testimonial={3} />;
        case "faq":
          return <Faq />;
        case "page_cta":
          return <CallToAction content={section} />;
        default:
          return null;
      }
    })
  }
</Base>
