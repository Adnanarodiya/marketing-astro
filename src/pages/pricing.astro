---
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import CallToAction from "@/partials/CallToAction.astro";
import Clients from "@/partials/Clients.astro";
import Faq from "@/partials/Faq.astro";
import PricingSection from "@/partials/PricingSection.astro";
import Testimonial from "@/partials/Testimonial.astro";

const pricing = await getListPage(
  "pricing",
  "-index"
);
if(pricing.data.draft){
  return Astro.redirect("/404");
}
const { sections } = pricing.data;
---

<Base {...pricing.data}>
  {
    sections?.map((section) => {
      if (section.enable === false) {
        return null;
      }

      switch (section.type) {
        case "pricing":
          return <PricingSection largeHeading={true} content={section} />;
        case "clients":
          return <Clients content={section} />;
        case "testimonial":
          return <Testimonial content={section} visible_testimonial={3} />;
        case "faq":
          return <Faq />;
        case "page_cta":
          return <CallToAction content={section} />;
        default:
          return null;
      }
    })
  }
</Base>
