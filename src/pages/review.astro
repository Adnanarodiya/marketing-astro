---
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import CallToAction from "@/partials/CallToAction.astro";
import Testimonial from "@/partials/Testimonial.astro";

const locale = Astro.currentLocale || "de";
const review = await getListPage(
  "review",
  `${locale}/-index`
);

if (review.data.draft) {
  return Astro.redirect(locale === "en" ? "/en/404" : "/404");
}
const { testimonial } = review.data;
---

<Base {...review.data}>
  <Testimonial largeHeading content={testimonial} />
  <CallToAction />
</Base>
