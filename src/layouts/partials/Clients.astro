---
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";

const { content } = Astro.props;

const defaultData = await getListPage("clientsSection", "clients");
const sectionData = {
  data: {
    ...defaultData.data,
    ...(content || {})
  }
};

if(!sectionData.data.enable){
  return null;
}

const { title, list } = sectionData.data;
---

<section class="section">
  <div class="container">
    <div class="row">
      <div class="col-12" data-aos="fade-up-sm">
        <div class="text-center sm:flex">
          <p
            class="w-full pb-3 text-center font-medium tracking-wide sm:whitespace-nowrap sm:pb-0 text-lg"
            set:html={markdownify(title)}
          />
        </div>
      </div>
      <div class="col-12 pt-10" data-aos="fade-up-sm" data-aos-delay="200">
        <div
          class="flex justify-center gap-x-12 gap-y-6 grayscale opacity-50 max-lg:flex-wrap">
          {
            list?.map((logo: any) => (
              <div class="flex aspect-[3.125/1] w-36 items-center">
                <img src={logo} alt="brand logo" title="brand logo" height="120" />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
