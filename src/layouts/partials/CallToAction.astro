---
import ImageMod from "@/components/ImageMod.astro";
import DynamicIcon from "@/helpers/DynamicIcon";
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";

const { content } = Astro.props;

const defaultData = await getListPage("ctaSection", "call-to-action");
const sectionData = {
  data: {
    ...defaultData.data,
    ...(content || {})
  }
};
if(!sectionData.data.enable){
  return null;
}
const { enable = true, title, description, image = "/images/cta-bg.svg", button, secondary_link } = sectionData.data;
---

{
  enable && (
    <section class="section mb-14">
      <div class="container">
        <div class="bg-text-dark px-10 py-16 xl:p-20 rounded-[40px] relative overflow-hidden">
          <div
            class="absolute top-1/2! -translate-y-1/2! left-1/2! -translate-x-1/2! rotate-[7.83deg] pointer-events-none"
            data-aos="fade-in"
            data-aos-delay="200">
            <ImageMod class=" h-[641px] w-auto " src={image} alt="cta-image" title="cta-image" />
          </div>
          <div class="row items-center justify-center">
            <div class="lg:col-8 text-center">
              <h2
                set:html={markdownify(title)}
                class="text-text-light mb-4"
                data-aos="fade-up-sm"
              />
              <p
                set:html={markdownify(description)}
                class="text-text-light text-lg/[inherit] mb-6"
                data-aos="fade-up-sm"
                data-aos-delay="50"
              />
              <div class="flex flex-wrap justify-center gap-4 relative z-10">
                {button?.enable && (
                  <a
                    class="btn btn-primary-light"
                    href={button.link}
                    title={button.label}
                    target={button.link.startsWith("http") ? "_blank" : "_self"}
                    rel="noopener"
                    data-aos="fade-up-sm"
                    data-aos-delay="200">
                    {button.label}
                    <span class="icon-wrapper">
                      <span class="icon">
                        <DynamicIcon icon={"FaArrowRight"} />
                      </span>
                      <span class="icon" aria-hidden="true">
                        <DynamicIcon icon={"FaArrowRight"} />
                      </span>
                    </span>
                  </a>
                )}
                {secondary_link?.enable && (
                  <a
                    class="btn btn-outline-light"
                    href={secondary_link.link}
                    title={secondary_link.label}
                    target={secondary_link.link.startsWith("http") ? "_blank" : "_self"}
                    rel="noopener"
                    data-aos="fade-up-sm"
                    data-aos-delay="250">
                    {secondary_link.label}
                    <span class="icon-wrapper">
                      <span class="icon">
                        <DynamicIcon icon={"FaArrowRight"} />
                      </span>
                      <span class="icon" aria-hidden="true">
                        <DynamicIcon icon={"FaArrowRight"} />
                      </span>
                    </span>
                  </a>
                )}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
