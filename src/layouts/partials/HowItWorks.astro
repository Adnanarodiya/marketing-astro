---
import ImageMod from "@/components/ImageMod.astro";
import DynamicIcon from "@/helpers/DynamicIcon";
const locale = Astro.currentLocale || "de";
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
const { content } = Astro.props;
let sectionData;
if (content) {
  sectionData = {
    data: {
      enable: content.enable !== false,
      title: content.title,
      subtitle: content.subtitle || "",
      description: content.description || content.content || "",
      list: content.list || content.items?.map((item: any, index: number) => ({
        icon: item.icon || item.logo || null,
        title: item.title,
        description: item.description || item.content,
        index,
      })) || [],
      button: content.button || null
    }
  };
} else {
  sectionData = await getListPage("howItWorksSection", `${locale}/how-it-works`);
}

if(!sectionData.data.enable){
  return null;
}

const { title, subtitle, description, list, button } = sectionData.data as any;
---

<section class="section">
  <div class="container">
    <div class="row">
      <div class="mx-auto text-center lg:col-10" data-aos="fade-up-sm">
        {
          subtitle && (
            <p
              class="mb-2 text-tertiary font-medium"
              set:html={markdownify(subtitle)}
            />
          )
        }
        {title && <h2 class="mb-6" set:html={markdownify(title)} />}
        {
          description && (
            <p class="text-lg/[inherit]" set:html={markdownify(description)} />
          )
        }
      </div>
      <div class="col-12 pt-20">
        <div class="row g-4 justify-center">
          {
            list?.map((item: any, index: number) => (
              <div
                class="md:col-6 lg:col-4"
                data-aos="fade-up-sm"
                data-aos-delay={index * 100}>
                <div class="min-h-full rounded-xl bg-light px-6 py-12 text-center md:rounded-3xl">
                  {(item.icon || item.index !== undefined) && (
                    <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-tertiary text-text-light font-bold">
                      {item.icon && item.icon.includes(":") ? (
                        <DynamicIcon icon={item.icon} className="text-2xl text-white" />
                      ) : item.icon ? (
                        <ImageMod
                          class="h-6 w-6 object-cover"
                          src={item.icon}
                          alt={`icon related to ${item.title}`}
                          title={`icon related to ${item.title}`}
                        />
                      ) : (
                        <span>{item.index + 1}</span>
                      )}
                    </div>
                  )}
                  {item.title && (
                    <h3 class="h5 mb-2" set:html={markdownify(item.title)} />
                  )}
                  {item.description && (
                    <p set:html={markdownify(item.description)} />
                  )}
                </div>
              </div>
            ))
          }
        </div>
        {
          button?.enable && (
            <div class="text-center mt-12" data-aos="fade-up-sm">
              <a class="btn btn-primary" href={button.link} title={button.label}>
                {button.label}
                <span class="icon-wrapper">
                  <span class="icon">
                    <DynamicIcon icon={"FaArrowRight"} />
                  </span>
                  <span class="icon" aria-hidden="true">
                    <DynamicIcon icon={"FaArrowRight"} />
                  </span>
                </span>
              </a>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
