---
import config from "@/config/config.json";
import ImageMod from "./ImageMod.astro";
import { getRelativeLocaleUrl } from "astro:i18n";

const { src, srcDarkmode }: { src?: string; srcDarkmode?: string } =
  Astro.props;
const {
  logo,
  logo_darkmode,
  logo_width,
  logo_height,
  logo_text,
  title,
}: {
  logo: string;
  logo_darkmode?: string;
  logo_width: any;
  logo_height: any;
  logo_text: string;
  title: string;
} = config.site;

const locale = Astro.currentLocale || "de";
---

<a href={getRelativeLocaleUrl(locale, "/")} class="navbar-brand inline-block" title={title}>
  {
    src || srcDarkmode || logo || logo_darkmode ? (
      <ImageMod
        src={src ? src : logo}
        class={`inline-block w-auto`}
        width={logo_width.replace("px", "") * 2}
        height={logo_height.replace("px", "") * 2}
        alt={title}
        title={title}
        style={{
          height: logo_height.replace("px", "") + "px",
          width: "auto",
        }}
        format="webp"
      />
    ) : logo_text ? (
      logo_text
    ) : (
      title
    )
  }
</a>
